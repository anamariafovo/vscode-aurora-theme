    "editor.wordHighlightBackground":        "#3060a820",
    "editor.wordHighlightStrongBackground":  "#3060a840",
    "editor.findMatchBackground":            "#8a650040",
    "editor.findMatchHighlightBackground":   "#8a650020",
    "editor.rangeHighlightBackground":       "#3060a810",
    "editorCursor.foreground":               "#007a62",
    "editorLineNumber.foreground":           "#c8c0f4",
    "editorLineNumber.activeForeground":     "#6878a8",
    "editorIndentGuide.background1":         "#e2dcfc",
    "editorIndentGuide.activeBackground1":   "#b8b0e8",
    "editorWhitespace.foreground":           "#b8b0e8",
