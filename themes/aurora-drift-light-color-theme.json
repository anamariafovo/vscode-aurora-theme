    "editorBracketHighlight.foreground1":    "#3060a8",
    "editorBracketHighlight.foreground2":    "#b04878",
    "editorBracketHighlight.foreground3":    "#007a62",
    "editorBracketHighlight.foreground4":    "#8a6500",
    "editorBracketHighlight.foreground5":    "#7048a8",
    "editorBracketHighlight.foreground6":    "#1068a0",
