    "editorError.foreground":                "#b04858",
    "editorWarning.foreground":              "#8a6500",
    "editorInfo.foreground":                 "#3060a8",
    "editorHint.foreground":                 "#007a62",
    "editorOverviewRuler.border":            "#f4f2ff",
    "editorOverviewRuler.addedForeground":   "#006050",
    "editorOverviewRuler.deletedForeground": "#b04858",
    "editorOverviewRuler.modifiedForeground":"#245090",
    "editorOverviewRuler.errorForeground":   "#b04858",
    "editorOverviewRuler.warningForeground": "#8a6500",
    "editorOverviewRuler.findMatchForeground":"#8a6500",
    "editorOverviewRuler.selectionHighlightForeground":"#007a62",

    "activityBar.background":               "#f4f2ff",
    "activityBar.foreground":               "#3060a8",
    "activityBar.inactiveForeground":       "#c8c0f4",
    "activityBar.border":                   "#ece8ff",
    "activityBarBadge.background":          "#b04878",
    "activityBarBadge.foreground":          "#f4f2ff",

    "sideBar.background":                   "#ece8ff",
    "sideBar.foreground":                   "#1e2240",
    "sideBar.border":                       "#e2dcfc",
    "sideBarTitle.foreground":              "#606888",
    "sideBarSectionHeader.background":      "#ece8ff",
    "sideBarSectionHeader.foreground":      "#606888",
    "sideBarSectionHeader.border":          "#e2dcfc",

    "list.activeSelectionBackground":       "#d4cef8",
