    "statusBar.background":                 "#f4f2ff",
    "statusBar.foreground":                 "#606888",
    "statusBar.border":                     "#e2dcfc",
    "statusBar.noFolderBackground":         "#f4f2ff",
    "statusBar.debuggingBackground":        "#903060",
    "statusBar.debuggingForeground":        "#f4f2ff",
    "statusBarItem.remoteBackground":       "#3060a8",
    "statusBarItem.remoteForeground":       "#f4f2ff",
    "statusBarItem.hoverBackground":        "#e2dcfc",

    "titleBar.activeBackground":            "#f4f2ff",
    "titleBar.activeForeground":            "#6878a8",
    "titleBar.inactiveBackground":          "#f4f2ff",
    "titleBar.inactiveForeground":          "#c8c0f4",
    "titleBar.border":                      "#ece8ff",

    "tab.activeBackground":                 "#f4f2ff",
    "tab.activeForeground":                 "#1e2240",
    "tab.activeBorder":                     "#007a62",
    "tab.inactiveBackground":               "#ece8ff",
    "tab.inactiveForeground":               "#606888",
    "tab.hoverBackground":                  "#e2dcfc",
    "tab.border":                           "#ece8ff",
    "editorGroupHeader.tabsBackground":     "#ece8ff",
    "editorGroupHeader.tabsBorder":         "#ece8ff",

    "panel.background":                     "#f4f2ff",
    "panel.border":                         "#e2dcfc",
    "panelTitle.activeBorder":              "#007a62",
    "panelTitle.activeForeground":          "#1e2240",
    "panelTitle.inactiveForeground":        "#606888",

    "terminal.background":                  "#f4f2ff",
    "terminal.foreground":                  "#1e2240",
    "terminal.ansiBlack":                   "#1e2240",
    "terminal.ansiBlue":                    "#3060a8",
    "terminal.ansiBrightBlack":             "#6878a8",
    "terminal.ansiBrightBlue":              "#6090d0",
    "terminal.ansiBrightCyan":              "#509898",
    "terminal.ansiBrightGreen":             "#38a888",
    "terminal.ansiBrightMagenta":           "#c06090",
    "terminal.ansiBrightRed":               "#c06070",
    "terminal.ansiBrightWhite":             "#1e2240",
    "terminal.ansiBrightYellow":            "#b09020",
    "terminal.ansiCyan":                    "#1068a0",
    "terminal.ansiGreen":                   "#007a62",
    "terminal.ansiMagenta":                 "#b04878",
    "terminal.ansiRed":                     "#b04858",
    "terminal.ansiWhite":                   "#3a4468",
    "terminal.ansiYellow":                  "#8a6500",
    "terminal.selectionBackground":         "#007a6230",
    "terminalCursor.foreground":            "#007a62",

    "input.background":                     "#ece8ff",
    "input.foreground":                     "#1e2240",
    "input.border":                         "#b8b0e8",
    "input.placeholderForeground":          "#606888",
    "inputOption.activeBorder":             "#007a62",
    "inputOption.activeBackground":         "#007a6220",
    "inputOption.activeForeground":         "#007a62",
    "inputValidation.errorBackground":      "#b0485818",
    "inputValidation.errorBorder":          "#b04858",
    "inputValidation.warningBackground":    "#8a650018",
    "inputValidation.warningBorder":        "#8a6500",
    "inputValidation.infoBackground":       "#3060a818",
    "inputValidation.infoBorder":           "#3060a8",

    "dropdown.background":                  "#ece8ff",
    "dropdown.foreground":                  "#1e2240",
    "dropdown.border":                      "#b8b0e8",

    "button.background":                    "#007a62",
    "button.foreground":                    "#f4f2ff",
    "button.hoverBackground":               "#006050",
    "button.secondaryBackground":           "#d4cef8",
    "button.secondaryForeground":           "#1e2240",
    "button.secondaryHoverBackground":      "#c8c0f4",

    "badge.background":                     "#b04878",
    "badge.foreground":                     "#f4f2ff",

    "progressBar.background":               "#007a62",

    "scrollbar.shadow":                     "#b8b0e860",
    "scrollbarSlider.background":           "#b8b0e860",
    "scrollbarSlider.hoverBackground":      "#b8b0e890",
    "scrollbarSlider.activeBackground":     "#007a6240",

    "notifications.background":             "#ece8ff",
    "notifications.foreground":             "#1e2240",
    "notifications.border":                 "#b8b0e8",
    "notificationLink.foreground":          "#3060a8",

    "focusBorder":                          "#007a6260",
    "foreground":                           "#1e2240",
    "descriptionForeground":                "#6878a8",
    "errorForeground":                      "#b04858",
    "icon.foreground":                      "#6878a8",
    "widget.shadow":                        "#b8b0e880",
    "selection.background":                 "#007a6230",
    "textLink.foreground":                  "#3060a8",
    "textLink.activeForeground":            "#245090",

    "gitDecoration.addedResourceForeground":        "#007a62",
    "gitDecoration.deletedResourceForeground":      "#b04858",
    "gitDecoration.modifiedResourceForeground":     "#3060a8",
    "gitDecoration.untrackedResourceForeground":    "#8a6500",
    "gitDecoration.ignoredResourceForeground":      "#c8c0f4",
    "gitDecoration.conflictingResourceForeground":  "#b04878",
    "gitDecoration.stageAddedResourceForeground":   "#007a62",
    "gitDecoration.stageDeletedResourceForeground": "#b04858",
    "gitDecoration.stageModifiedResourceForeground":"#3060a8",

    "peekView.border":                      "#3060a8",
    "peekViewEditor.background":            "#ece8ff",
    "peekViewEditor.matchHighlightBackground":"#8a650030",
    "peekViewResult.background":            "#f4f2ff",
    "peekViewResult.fileForeground":        "#1e2240",
    "peekViewResult.lineForeground":        "#6878a8",
    "peekViewResult.matchHighlightBackground":"#8a650030",
    "peekViewResult.selectionBackground":   "#e2dcfc",
    "peekViewResult.selectionForeground":   "#1e2240",
    "peekViewTitle.background":             "#f4f2ff",
    "peekViewTitleLabel.foreground":        "#1e2240",
    "peekViewTitleDescription.foreground":  "#6878a8",

    "diffEditor.insertedTextBackground":    "#007a6215",
    "diffEditor.removedTextBackground":     "#b0485815",
    "diffEditor.insertedLineBackground":    "#007a6210",
    "diffEditor.removedLineBackground":     "#b0485810",

    "debugToolBar.background":              "#ece8ff",
    "debugIcon.breakpointForeground":       "#b04858",
    "debugIcon.breakpointCurrentStackframeForeground": "#8a6500",
    "debugIcon.startForeground":            "#007a62",

    "breadcrumb.foreground":                "#606888",
    "breadcrumb.focusForeground":           "#1e2240",
    "breadcrumb.activeSelectionForeground": "#1e2240",
    "breadcrumbPicker.background":          "#ece8ff",

    "menu.background":                      "#ece8ff",
    "menu.foreground":                      "#1e2240",
    "menu.selectionBackground":             "#d4cef8",
    "menu.selectionForeground":             "#1e2240",
    "menu.separatorBackground":             "#b8b0e8",
    "menubar.selectionBackground":          "#e2dcfc",
    "menubar.selectionForeground":          "#1e2240",

    "charts.blue":                          "#3060a8",
    "charts.green":                         "#007a62",
    "charts.yellow":                        "#8a6500",
    "charts.red":                           "#b04858",
    "charts.orange":                        "#905820",
    "charts.purple":                        "#7048a8",
    "charts.foreground":                    "#1e2240",
    "charts.lines":                         "#b8b0e8"
  },

  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#606888", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#8a6500" }
    },
    {
      "name": "String escape / special characters",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#905820" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#b04878" }
    },
    {
      "name": "Booleans / null / undefined",
      "scope": ["constant.language"],
      "settings": { "foreground": "#b04878", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.in",
        "keyword.operator.of",
        "storage",
        "storage.type"
      ],
      "settings": { "foreground": "#3060a8" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "punctuation.separator"],
      "settings": { "foreground": "#6878a8" }
    },
    {
      "name": "Functions / methods",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "support.function"
      ],
      "settings": { "foreground": "#007a62" }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#1068a0", "fontStyle": "italic" }
    },
    {
      "name": "Classes / types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": { "foreground": "#7048a8" }
    },
    {
      "name": "Type annotations / generics",
      "scope": [
        "entity.name.type.alias",
        "entity.name.type.interface",
        "meta.type.annotation",
        "support.type"
      ],
      "settings": { "foreground": "#1068a0" }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": { "foreground": "#905820" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#1e2240" }
    },
    {
      "name": "Object properties / member access",
      "scope": [
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.variable.property"
      ],
      "settings": { "foreground": "#3a4468" }
    },
    {
      "name": "Constants / enum members",
      "scope": ["variable.other.constant", "variable.other.enummember"],
      "settings": { "foreground": "#b04878" }
    },
    {
      "name": "Modules / namespaces",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "variable.other.module"
      ],
      "settings": { "foreground": "#3060a8" }
    },
    {
      "name": "Import / export keywords",
      "scope": ["keyword.control.import", "keyword.control.export"],
      "settings": { "foreground": "#3060a8" }
    },
    {
      "name": "Imported name",
      "scope": ["variable.other.readwrite.alias"],
      "settings": { "foreground": "#1e2240" }
    },

    {
      "name": "HTML tags",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#b04878" }
    },
    {
      "name": "HTML attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#1068a0" }
    },
    {
      "name": "HTML attribute values",
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": { "foreground": "#8a6500" }
    },
    {
      "name": "HTML / XML punctuation",
      "scope": [
        "punctuation.definition.tag",
        "meta.tag.sgml"
      ],
      "settings": { "foreground": "#606888" }
    },

    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": { "foreground": "#007a62" }
    },
    {
      "name": "CSS properties",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#3060a8" }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": { "foreground": "#8a6500" }
    },
    {
      "name": "CSS units",
      "scope": ["keyword.other.unit.css"],
      "settings": { "foreground": "#b04878" }
    },
    {
      "name": "CSS at-rules",
      "scope": ["keyword.control.at-rule"],
      "settings": { "foreground": "#7048a8" }
    },

    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#3060a8" }
    },
    {
      "name": "JSON string values",
      "scope": ["string.quoted.double.json"],
      "settings": { "foreground": "#8a6500" }
    },
    {
      "name": "JSON boolean / null",
      "scope": ["constant.language.json"],
      "settings": { "foreground": "#b04878", "fontStyle": "italic" }
    },

    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": { "foreground": "#3060a8", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#8a6500", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#b04878", "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#007a62" }
    },
    {
      "name": "Markdown link",
      "scope": ["string.other.link.title.markdown"],
      "settings": { "foreground": "#7048a8" }
    },
    {
      "name": "Markdown link URL",
      "scope": ["markup.underline.link.markdown"],
      "settings": { "foreground": "#1068a0" }
    },
    {
      "name": "Markdown blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#606888", "fontStyle": "italic" }
    },
    {
      "name": "Markdown list bullet",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": { "foreground": "#007a62" }
    },

    {
      "name": "Punctuation / brackets",
      "scope": [
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": { "foreground": "#6878a8" }
    },
    {
      "name": "Invalid / deprecated",
      "scope": ["invalid"],
      "settings": { "foreground": "#b04858", "fontStyle": "underline" }
    },
    {
      "name": "Diff added",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#007a62" }
    },
    {
      "name": "Diff removed",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#b04858" }
    },
    {
      "name": "Diff changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#3060a8" }
    }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace":         "#3060a8",
    "type":              "#1068a0",
    "class":             "#7048a8",
    "interface":         "#1068a0",
    "typeParameter":     "#1068a0",
    "function":          "#007a62",
    "method":            "#007a62",
    "property":          "#3a4468",
    "variable":          "#1e2240",
    "variable.constant": "#b04878",
    "parameter":         { "foreground": "#1068a0", "italic": true },
    "enumMember":        "#b04878",
    "decorator":         "#905820",
    "comment":           { "foreground": "#606888", "italic": true },
    "string":            "#8a6500",
    "number":            "#b04878",
    "keyword":           "#3060a8",
    "operator":          "#6878a8",
    "macro":             "#905820",
    "label":             "#6878a8"
  }
}
