{
  "$schema": "vscode://schemas/color-theme",
  "name": "Aurora Drift Light",
  "type": "light",

  "_palette": {
    "bg0":       "#f4f2ff",
    "bg1":       "#ece8ff",
    "bg2":       "#e2dcfc",
    "bg3":       "#d4cef8",
    "bg4":       "#c8c0f4",
    "border":    "#b8b0e8",
    "comment":   "#606888",
    "muted":     "#6878a8",
    "fg":        "#1e2240",
    "fgDim":     "#3a4468",

    "blue":      "#3060a8",
    "blueDim":   "#245090",
    "cyan":      "#1068a0",
    "green":     "#007a62",
    "greenDim":  "#006050",
    "yellow":    "#8a6500",
    "yellowDim": "#6e5000",
    "pink":      "#b04878",
    "pinkDim":   "#903060",
    "purple":    "#7048a8",
    "red":       "#b04858",
    "orange":    "#905820"
  },

  "colors": {
    "editor.background":                     "#f4f2ff",
    "editor.foreground":                     "#1e2240",
    "editor.lineHighlightBackground":        "#e2dcfc80",
